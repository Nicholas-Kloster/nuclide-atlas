#!/usr/bin/env python3
"""Atlas zero-config bootstrap.

Discovers LLM services, writes config/atlas.yaml, boots the stack via
docker compose, opens the browser. Exit codes are stable so the CLAUDE.md
playbook can branch on them.

Usage:
  bin/atlas-bootstrap                 # default: discover + docker compose up
  bin/atlas-bootstrap --dry-run       # discover and write yaml only
  bin/atlas-bootstrap --port 3001     # bind a different UI port
  bin/atlas-bootstrap --no-open       # skip webbrowser.open
  bin/atlas-bootstrap --keep-config   # don't overwrite existing atlas.yaml

Exit codes:
   0  ok
  64  no LLM services found anywhere (EXIT_NO_SERVICES)
  65  docker not available (EXIT_NO_DOCKER)
  66  requested port already in use (EXIT_PORT_IN_USE)
"""

from __future__ import annotations

import argparse
import datetime as dt
import os
import socket
import subprocess
import sys
import webbrowser
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "backend"))

from app.discovery import run_discovery  # noqa: E402

EXIT_NO_SERVICES = 64
EXIT_NO_DOCKER = 65
EXIT_PORT_IN_USE = 66

CONFIG_PATH = ROOT / "config" / "atlas.yaml"


def _docker_available() -> bool:
    try:
        return subprocess.run(
            ["docker", "version"],
            capture_output=True,
            timeout=4,
        ).returncode == 0
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


def _port_free(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        try:
            s.bind(("127.0.0.1", port))
            return True
        except OSError:
            return False


def _stage(label: str, msg: str) -> None:
    print(f"{label} {msg}", flush=True)


def main() -> int:
    parser = argparse.ArgumentParser(prog="atlas-bootstrap")
    parser.add_argument("--port", type=int, default=3000)
    parser.add_argument("--dry-run", action="store_true",
                        help="discover + write yaml; skip docker boot")
    parser.add_argument("--no-open", action="store_true")
    parser.add_argument("--keep-config", action="store_true",
                        help="preserve existing config/atlas.yaml if present")
    parser.add_argument("--k8s-namespace", default=None,
                        help="if set, include kubectl probe scoped to namespace")
    parser.add_argument("--local-host", action="append", default=None,
                        help="additional host(s) to probe (repeatable)")
    args = parser.parse_args()

    _stage("[1/4]", "discovering LLM services on this machine ...")
    hosts = ("127.0.0.1",) + tuple(args.local_host or ())
    result = run_discovery(
        local_hosts=hosts,
        include_k8s=args.k8s_namespace is not None,
        k8s_namespace=args.k8s_namespace,
    )

    if result.is_empty():
        print("  no LLM services detected via env vars, localhost ports, docker, or k8s.")
        print("  paste a URL into the UI's '+ Add source' panel, or set OLLAMA_HOST / "
              "OPENAI_API_BASE / OPENAI_BASE_URL and re-run.")
        return EXIT_NO_SERVICES

    print(f"  sources run: {', '.join(result.sources_run)}")
    result.print_summary("  ")

    if args.keep_config and CONFIG_PATH.exists():
        _stage("[2/4]", f"keeping existing {CONFIG_PATH.relative_to(ROOT)} as requested")
    else:
        _stage("[2/4]", f"writing {CONFIG_PATH.relative_to(ROOT)}")
        result.write_yaml(
            CONFIG_PATH,
            header=f"generated by atlas-bootstrap on "
                   f"{dt.datetime.now(dt.timezone.utc).isoformat(timespec='seconds')}",
        )
        print(f"  {result.node_summary()}")

    if args.dry_run:
        _stage("[3/4]", "--dry-run set, skipping docker boot")
        _stage("[4/4]", "done")
        return 0

    if not _port_free(args.port):
        print(f"  port {args.port} already in use. retry with --port N.")
        return EXIT_PORT_IN_USE

    if not _docker_available():
        print("  docker not found.")
        print("  install docker + docker compose, or run uvicorn / vite by hand "
              "(see README 'Local development without containers').")
        return EXIT_NO_DOCKER

    _stage("[3/4]", "docker compose up -d --build")
    env = os.environ.copy()
    env["ATLAS_UI_PORT"] = str(args.port)
    rc = subprocess.run(
        ["docker", "compose", "up", "-d", "--build"],
        cwd=ROOT,
        env=env,
    ).returncode
    if rc != 0:
        return rc

    url = f"http://localhost:{args.port}"
    _stage("[4/4]", url)
    if not args.no_open:
        try:
            webbrowser.open(url)
        except Exception:
            pass
    return 0


if __name__ == "__main__":
    sys.exit(main())
