#!/usr/bin/env python3
"""Atlas demo — spawn fake LLM services so you can try the tool with no infra.

Boots three stdlib-only HTTP servers on localhost:
  :19101  mock Ollama   (`/api/tags`)
  :19102  mock vLLM     (`/v1/models`)
  :19103  mock Qdrant   (`/collections`)

Then runs `bin/atlas-bootstrap --local-host 127.0.0.1` which discovers
them, writes config/atlas.yaml, and (if Docker is available) boots the UI.

Stop the servers with Ctrl-C; they're not detached.
"""

from __future__ import annotations

import json
import signal
import subprocess
import sys
import threading
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]


# ── handlers ────────────────────────────────────────────────────────────

class _Mock(BaseHTTPRequestHandler):
    routes: dict[str, tuple[int, dict]] = {}

    def do_GET(self):  # noqa: N802
        body = None
        for path, (status, payload) in self.routes.items():
            if self.path.startswith(path):
                body = json.dumps(payload).encode()
                self.send_response(status)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return
        self.send_response(404)
        self.end_headers()

    def log_message(self, *_args):  # silence default access log
        return


def make_handler(routes: dict[str, tuple[int, dict]]) -> type[_Mock]:
    cls = type("MockHandler", (_Mock,), {"routes": routes})
    return cls


# ── service shapes ──────────────────────────────────────────────────────

OLLAMA = {
    "/api/tags": (200, {
        "models": [
            {"name": "llama3:8b", "size": 4731112960, "digest": "demo"},
            {"name": "mistral:7b", "size": 4112112960, "digest": "demo"},
            {"name": "nomic-embed-text", "size": 274112960, "digest": "demo"},
        ]
    }),
    "/api/version": (200, {"version": "0.5.demo"}),
}

VLLM = {
    "/v1/models": (200, {
        "object": "list",
        "data": [
            {"id": "meta-llama/Llama-3-8B-Instruct", "object": "model", "owned_by": "demo"},
        ],
    }),
}

QDRANT = {
    "/collections": (200, {
        "result": {
            "collections": [
                {"name": "docs"},
                {"name": "tickets"},
            ]
        },
        "status": "ok",
    }),
}


# ── orchestration ───────────────────────────────────────────────────────

def _serve(port: int, routes: dict[str, tuple[int, dict]]) -> ThreadingHTTPServer:
    srv = ThreadingHTTPServer(("127.0.0.1", port), make_handler(routes))
    threading.Thread(target=srv.serve_forever, daemon=True).start()
    return srv


def main() -> int:
    servers: list[ThreadingHTTPServer] = []
    targets = [
        (11434, OLLAMA, "ollama"),
        (8000, VLLM, "vllm"),
        (6333, QDRANT, "qdrant"),
    ]
    chosen: list[tuple[int, str]] = []
    print("[demo] starting mock services on loopback:")
    for port, routes, label in targets:
        try:
            srv = _serve(port, routes)
        except OSError:
            print(f"  {label:8s}  port {port} in use; skipping")
            continue
        servers.append(srv)
        chosen.append((port, label))
        print(f"  {label:8s}  http://127.0.0.1:{port}")
    if not servers:
        print("[demo] no free ports — stop whatever is on 11434/8000/6333 and re-run.")
        return 2

    # give the servers a beat to settle before discovery
    time.sleep(0.2)

    print("[demo] running bin/atlas-bootstrap ...")
    bootstrap = ROOT / "bin" / "atlas-bootstrap"
    proc = subprocess.run(
        [str(bootstrap)] + sys.argv[1:],
        cwd=ROOT,
    )

    if proc.returncode != 0:
        print(f"[demo] bootstrap exited {proc.returncode}; mock services still running.")
    print("[demo] mock services up. Ctrl-C to stop.")

    stop = threading.Event()

    def _on_sig(*_):
        stop.set()
    signal.signal(signal.SIGINT, _on_sig)
    signal.signal(signal.SIGTERM, _on_sig)
    stop.wait()
    for s in servers:
        s.shutdown()
    return 0


if __name__ == "__main__":
    sys.exit(main())
